# Connection to the database the worker is responsible for. Should point
# at PROD when deployed to Hetzner. Pooler URL is fine; the worker only
# uses a single connection at a time.
#
# Example: postgres://postgres:<password>@db.fabxmporizzqflnftavs.supabase.co:5432/postgres
DATABASE_URL=

# Storage bucket access. The worker uses the service-role JWT (not the
# DATABASE_URL) for storage operations because storage.copy across
# buckets goes through PostgREST/storage-api.
SUPABASE_URL=https://fabxmporizzqflnftavs.supabase.co
SUPABASE_SERVICE_ROLE=

# How often the polling loop wakes up to look for new QUEUED jobs.
# Lower = faster pickup, more idle DB chatter. 10s is fine for human-
# initiated admin deletes; bump to 60s if jobs are rare.
POLL_INTERVAL_MS=10000

# Optional: override the hostname recorded in private.worker_runs.host.
# Defaults to os.hostname(). Useful when multiple workers run from the
# same container image and you want them distinguishable.
WORKER_HOST_LABEL=

# Optional: log level for pino. Default 'info'. Set 'debug' to see every
# poll cycle, 'warn' to suppress per-job heartbeats.
LOG_LEVEL=info
